# Required for --execute (on-chain funding)
PRIVATE_KEY=

# Optional: custom API base URL (defaults to https://dropcast.xyz)
# DROPCAST_API_BASE_URL=https://dropcast.xyz

# Optional: custom RPC URL (defaults to https://mainnet.base.org)
# RPC_URL=https://mainnet.base.org

# Optional: custom Router contract address (defaults to production)
# DROPCAST_ROUTER_ADDRESS=0xd216801c9B658f9bEcB8125387a2A02c0d7Cc3d2
